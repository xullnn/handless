.DS_Store

# SwiftPM and Xcode local state
.build/
.swiftpm/
DerivedData/
*.xcuserstate

# Packaged app output
dist/

# Local Python runtimes
.venv/
.venv-*/

# Large local model/runtime caches
.external/

# Local/private ASR recordings
eval/asr_streaming/audio/
eval/asr_streaming/audio/*.wav
eval/asr_streaming/audio/*.m4a
eval/asr_streaming/audio/*.aiff
eval/asr_streaming/audio/*.caf

# Python cache files
__pycache__/
*.pyc

# Local/private runtime config
configs/config.local.json
configs/local*.json

# Local runtime logs and stale terminal reports
asr_logs/
test-report.txt
eval/asr_streaming/results/*download.log
eval/asr_streaming/results/**/*.log
eval/asr_streaming/results/**/*.pid
eval/asr_streaming/results/manual-use-*/
eval/asr_streaming/results/manual-segmented-runtime-*/
eval/asr_streaming/results/*-spool/
eval/asr_streaming/results/**/*.f32le
